# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tokyo_listings

# Local dev: Next.js rewrites `/api` and `/trpc` to this API origin
API_DEV_ORIGIN=http://localhost:8787

# Better Auth — generate a long random string for production
BETTER_AUTH_SECRET=
# Public base URL of the app (web origin), e.g. http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# SMTP (verification + password reset). Use your provider’s host/port/credentials.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Google Maps — restrict keys per Google Cloud console (HTTP referrers / APIs enabled)
# Server-side (Geocoding, etc.)
GOOGLE_MAPS_SERVER_KEY=
# Client — Maps JavaScript API (browser)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional — Map ID if using cloud-based map styling
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
