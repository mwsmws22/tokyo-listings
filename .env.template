# Tokyo Listings — committed env template (copy to `.env` at repo root; gitignored).
# Root `package.json` scripts use `bun --env-file=.env`.
# For Compose, point `env_file` at `.env` from the compose file directory (often `docker/` — use `../.env`).

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tokyo_listings

# TCP port the Hono API HTTP server binds to (local dev and Docker).
API_LISTEN_PORT=4001

# Local dev: Next.js rewrites `/api` and `/trpc` to this API origin — use the same host/port as API_LISTEN_PORT
API_DEV_ORIGIN=http://localhost:4001

# Docker Compose — host port mapped to the web container (default 3000). Optional.
# WEB_PUBLISH_PORT=3000

# Better Auth — generate a long random string for production
BETTER_AUTH_SECRET=
# Public base URL of the app (web origin), e.g. http://localhost:3000 — must match the browser origin
BETTER_AUTH_URL=http://localhost:3000
# Same value as BETTER_AUTH_URL for the Better Auth client in the browser (see apps/web/src/lib/auth-client.ts)
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# SMTP (verification + password reset). Use your provider’s host/port/credentials.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Google Maps — restrict keys per Google Cloud console (HTTP referrers / APIs enabled)
# Server-side (Geocoding, etc.)
GOOGLE_MAPS_SERVER_KEY=
# Client — Maps JavaScript API (browser)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional — Map ID if using cloud-based map styling
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
