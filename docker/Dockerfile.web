# Next.js standalone (PostCSS + Uniwind + Tailwind v4 at build time) — context: repository root.
# syntax=docker/dockerfile:1

FROM oven/bun:1.2 AS deps
WORKDIR /app

COPY package.json bun.lock ./
COPY apps/api/package.json ./apps/api/
COPY apps/web/package.json ./apps/web/
COPY packages/db/package.json ./packages/db/
COPY packages/validators/package.json ./packages/validators/
RUN bun install --frozen-lockfile

FROM deps AS builder
COPY . .

# Next.js loads `.env` from the app directory (`apps/web`), not the monorepo root. Copy root `.env`
# when present (requires `!.env` in `.dockerignore`) so `GOOGLE_MAPS_*` are available during `next build`.
RUN if [ -f /app/.env ]; then cp /app/.env /app/apps/web/.env; fi

# Baked into `next.config` rewrites — use the Compose service name so the web container proxies to the API.
ARG API_DEV_ORIGIN=http://api:4001
ENV API_DEV_ORIGIN=${API_DEV_ORIGIN}

ARG NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
ENV NEXT_PUBLIC_BETTER_AUTH_URL=${NEXT_PUBLIC_BETTER_AUTH_URL}

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

WORKDIR /app/apps/web
RUN bun /app/node_modules/next/dist/bin/next build
WORKDIR /app

FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

EXPOSE 3000
CMD ["node", "apps/web/server.js"]
